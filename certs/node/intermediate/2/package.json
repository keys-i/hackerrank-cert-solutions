{
  "name": "express-authorization-middleware",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "bun run check",
    "check": "node --check \"app.js\" && node --check \"controllers/tasks.controller.js\" && node --check \"middleware.js\" && node --check \"routes/index.js\" && node --check \"routes/tasks.js\" && node --check \"test/index.spec.js\"",
    "start": "bun bin/www",
    "test": "PORT=8000 mocha --timeout 20000 \"test/**/*.js\" --reporter mocha-multi-reporters --reporter-options configFile=config.json --exit"
  },
  "dependencies": {
    "bluebird": "3.7.2",
    "cookie-parser": "1.4.7",
    "debug": "4.4.3",
    "express": "5.2.1",
    "morgan": "1.11.0",
    "pug": "3.0.4",
    "shortid": "2.2.17",
    "sinon": "22.0.0"
  },
  "devDependencies": {
    "bluebird": "3.7.2",
    "lodash": "4.18.1",
    "supertest": "7.2.2",
    "mocha": "11.7.6",
    "mocha-junit-reporter": "2.2.1",
    "chai": "4.5.0",
    "chai-http": "4.4.0",
    "mocha-multi-reporters": "1.5.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "diff": "9.0.0",
    "glob": "13.0.6",
    "js-yaml": "4.2.0",
    "serialize-javascript": "7.0.5",
    "uuid": "14.0.0"
  }
}
